{
    "name": "laravel/hello-world-api",
    "description": "Simple Laravel API with Hello World endpoint",
    "type": "project",
    "require": {
        "php": "^8.1",
        "anthropic-ai/sdk": "^0.5.0",
        "bytic/omnipay-euplatesc": "^3.0",
        "doctrine/dbal": "^3.10",
        "google/cloud-storage": "^1.49",
        "guzzlehttp/guzzle": "7.8",
        "laravel/framework": "^10.0",
        "laravel/passport": "^11.8",
        "league/flysystem-google-cloud-storage": "^3.31",
        "php-http/httplug": "^2.4",
        "pusher/pusher-php-server": "^7.2",
        "symfony/dotenv": "^6.4",
        "symfony/http-client": "^6.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "classmap": [
            "services/claude.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
